// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assets        Asset[]
  liabilities   Liability[]
  goals         Goal[]
  fireSettings  FireSettings?
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Float
  targetDate    DateTime
  priority      String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Asset {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String   // STOCK, MF, FD, REAL_ESTATE, GOLD, CRYPTO, CASH_BANK, OTHER
  name           String
  investedAmount Float
  returnRate     Float    // CAGR or expected return %
  interestType   String   @default("COMPOUND") // SIMPLE, COMPOUND
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modifications  AssetModification[]
}

model Liability {
  id                String   @id @default(cuid())
  userId            String
  type              String   // HOME_LOAN, CAR_LOAN, PERSONAL_LOAN, CREDIT_CARD, OTHER
  name              String
  outstandingAmount Float
  interestRate      Float
  emi               Float
  startDate         DateTime? // Date when loan started
  endDate           DateTime? // Estimated or Actual end date
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  modifications     LiabilityModification[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssetModification {
  id        String   @id @default(cuid())
  assetId   String
  amount    Float    // Positive for investment/bonus, Negative for withdrawal
  date      DateTime
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model LiabilityModification {
  id          String   @id @default(cuid())
  liabilityId String
  amount      Float    // Amount paid (reduces principal)
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  liability   Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
}

model FireSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualExpenses    Float    @default(0)
  inflationRate     Float    @default(6.0)
  safeWithdrawalRate Float   @default(4.0)
  currentAge        Int?
  retirementAgeGoal Int?
  maxAge            Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
